# ─── Configuração da API ──────────────────────────────────────────────
# Este app apenas CONSOME a API. A API é um projeto SEPARADO, mantido em
# outro repositório. Aqui você só informa ONDE ela está.
#
# Como usar:  copie este arquivo para .env  →  cp .env.example .env
# O .env é pessoal (está no .gitignore) — cada dev/máquina tem o seu.
#
# IMPORTANTE: após editar o .env, reinicie o Metro com:  npx expo start --clear
# (as variáveis EXPO_PUBLIC_* são embutidas no bundle no momento do build)

# URL da API que o app vai consumir.
#   auto                      -> detecta o IP do notebook automaticamente (modo LAN)
#   http://192.168.0.10:8080  -> fixa um endereço manualmente
EXPO_PUBLIC_API_URL=auto

# Origem dos dados:
#   true  -> modo DEMO: usa dados locais (fixtures), NÃO chama backend nenhum
#   false -> consome a API real definida em EXPO_PUBLIC_API_URL
EXPO_PUBLIC_MOCK_MODE=true
